# Core app
ENVIRONMENT=development
APP_NAME=Aflex Loans API
API_V1_PREFIX=/api/v1
PORT=8000
WEB_CONCURRENCY=1

# Auth
JWT_SECRET=replace-with-a-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-a-long-random-refresh-secret
ACCESS_TOKEN_EXPIRE_MINUTES=120
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# Database
# Local SQLite example:
DATABASE_URL=sqlite:///./aflex_loans.db
# Render + Neon example:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT_SECONDS=30
DB_POOL_RECYCLE_SECONDS=1800
RUN_MIGRATIONS_ON_STARTUP=false

# CORS
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8081,exp://127.0.0.1:19000

# Security / throttling
LOGIN_RATE_LIMIT_PER_MINUTE=10
OTP_RATE_LIMIT_PER_MINUTE=6

# Optional admin bootstrap for first startup
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_FULL_NAME=Aflex Loans Admin
BOOTSTRAP_ADMIN_PHONE=

# Uploads
UPLOAD_PROVIDER=cloudinary
UPLOAD_MAX_MB=8
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# OTP delivery
OTP_PROVIDER=console
OTP_ALLOW_DEBUG_CODE=true
OTP_REQUIRE_REAL_DELIVERY=false
OTP_SENDER_ID=

# Africa's Talking
OTP_AFRICASTALKING_USERNAME=
OTP_AFRICASTALKING_API_KEY=

# Twilio
OTP_TWILIO_ACCOUNT_SID=
OTP_TWILIO_AUTH_TOKEN=
OTP_TWILIO_SMS_FROM=
OTP_TWILIO_WHATSAPP_FROM=
OTP_TWILIO_VOICE_FROM=

# SMTP email OTP / notifications
OTP_SMTP_HOST=
OTP_SMTP_PORT=587
OTP_SMTP_USERNAME=
OTP_SMTP_PASSWORD=
OTP_SMTP_FROM_EMAIL=
OTP_SMTP_USE_TLS=true
OTP_TEST_REDIRECT_EMAIL=
LOAN_ADMIN_ALERT_EMAIL=
LOAN_USER_NOTIFICATION_EMAIL_OVERRIDE=

# Loan operations
MPESA_COLLECTION_PHONE=0721802110
DUE_REMINDER_ENABLED=true
DUE_REMINDER_DAYS_BEFORE=10
DUE_REMINDER_SCAN_INTERVAL_MINUTES=60

# Distribution / downloads
DISTRIBUTION_PUBLIC_BASE_URL=
DISTRIBUTION_INSTALL_PAGE_PATH=/install
DISTRIBUTION_APK_FILENAME=aflex-loans-latest.apk
DISTRIBUTION_DOWNLOADS_DIR=./downloads
DISTRIBUTION_BRAND_NAME=Aflex Loan
DISTRIBUTION_SUPPORT_PHONE=
DISTRIBUTION_SUPPORT_EMAIL=
